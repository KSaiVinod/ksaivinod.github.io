    "express": "^4.19.2",
    "lottie-web": "^5.13.0",
    "nodemailer": "^8.0.7",
    "pinia": "^3.0.4",
    "three": "^0.184.0",
    "uuid": "^9.0.1",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "concurrently": "^10.0.0",
    "nodemon": "^3.1.4",
    "vite": "^8.0.14"
  }
}
