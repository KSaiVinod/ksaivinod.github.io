{
  "name": "ksaivinod-portfolio",
  "version": "2.0.0",
  "type": "module",
  "description": "Sai Vinod portfolio — Vue 3 + Vite, three modes",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "api": "nodemon backend/server.cjs --port 4000",
    "dev:full": "concurrently \"npm run dev\" \"npm run api\"",
