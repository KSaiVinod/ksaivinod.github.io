{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vue",
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": { "maxLambdaSize": "10mb" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)",  "dest": "/backend/server.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)",      "dest": "/index.html" }
  ]
}
